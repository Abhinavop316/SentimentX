{
  "name": "sentimentx-graphql-api",
  "version": "1.0.0",
  "description": "GraphQL API for SentimentX AI-Driven Booth Management System",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --detectOpenHandles --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\"",
    "generate:schema": "node scripts/generateSchema.js",
    "db:seed": "node scripts/seedData.js"
  },
  "keywords": [
    "graphql",
    "neo4j",
    "apollo",
    "booth-management",
    "election",
    "india"
  ],
  "author": "SentimentX Team",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "graphql": "^16.8.1",
    "neo4j-driver": "^5.17.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.10",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
